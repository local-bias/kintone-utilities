{
  "name": "@konomi-app/kintone-utilities-cloud",
  "version": "2.0.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "repository": "https://github.com/local-bias/kintone-cloud-connector.git",
  "author": "adachi",
  "license": "MIT",
  "scripts": {
    "build": "tsup",
    "prepare": "npm run build"
  },
  "peerDependencies": {
    "@konomi-app/ketch": ">=0.2.0",
    "openai": ">=4.0.0",
    "qs": ">=6.0.0"
  },
  "devDependencies": {
    "@kintone/dts-gen": "^9.0.0",
    "@konomi-app/ketch": "^0.2.0",
    "@types/node": "^25.0.3",
    "@types/qs": "^6.14.0",
    "openai": "^6.15.0",
    "qs": "^6.14.0",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  },
  "prettier": {
    "printWidth": 100,
    "arrowParens": "always",
    "singleQuote": true,
    "jsxSingleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "endOfLine": "lf"
  }
}
